# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYCHANGU_SEC: Required for initiating Malawian mobile money payments.
# Obtain this from your Paychangu Dashboard (https://dashboard.paychangu.com)
VITE_PAYCHANGU_PUBLIC_KEY="YOUR_PAYCHANGU_PUBLIC_KEY"
PAYCHANGU_SEC="YOUR_PAYCHANGU_SEC"
PAYCHANGU_WEBHOOK_SECRET="YOUR_PAYCHANGU_WEBHOOK_SECRET"
VITE_APP_URL="YOUR_APP_URL"

# SUPABASE_URL & SUPABASE_ANON_KEY: Required for database and auth.
VITE_SUPABASE_URL="https://akclwguqzeijscftatqp.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFrY2x3Z3VxemVpanNjZnRhdHFwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc1MzgyMDUsImV4cCI6MjA5MzExNDIwNX0.ZcPAVUWpxFE0ba0QjzzSK7xOucWYKPci6JFPeXwLalc"
SUPA_ADMIN_KEY="YOUR_SUPA_ADMIN_KEY"

# Africa's Talking API (SMS)
AT_USERNAME="YOUR_AT_USERNAME"
AT_API_KEY="YOUR_AT_API_KEY"
